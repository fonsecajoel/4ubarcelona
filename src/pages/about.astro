---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="About Us">
  <Navbar slot="navbar" scrolled={true} />

  <!-- Hero Section -->
  <section class="relative min-h-[80vh] flex items-center justify-center overflow-hidden bg-[var(--primary)] text-white pt-20">
    <div class="absolute inset-0 z-0">
      <div class="absolute inset-0 bg-gradient-to-b from-[var(--primary)]/80 via-transparent to-[var(--primary)]/90 z-10"></div>
      <img src="https://images.unsplash.com/photo-1583422409516-2895a77efded?w=1920&q=80" alt="Barcelona skyline" class="w-full h-full object-cover animate-pan" />
    </div>
    
    <div class="container relative z-20 text-center">
      <h1 class="text-5xl md:text-7xl font-bold font-['Playfair_Display'] mb-6 opacity-0 animate-fade-up" style="animation-delay: 0.2s; animation-fill-mode: forwards;">Our City, <span class="text-[var(--gold)]">4U!</span></h1>
      <p class="text-xl md:text-2xl font-light max-w-2xl mx-auto opacity-0 animate-fade-up" style="animation-delay: 0.4s; animation-fill-mode: forwards;">Discover the soul of Barcelona with the locals who know its best-kept secrets.</p>
    </div>
  </section>

  <!-- Story Section (Timeline & Text) -->
  <section class="py-24 bg-white">
    <div class="container">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <!-- Timeline -->
        <div class="relative pl-8 border-l-2 border-[var(--gold)]/30 space-y-12">
          <div class="relative">
            <div class="absolute -left-[41px] top-1 w-5 h-5 rounded-full bg-[var(--gold)] border-4 border-white shadow-md"></div>
            <h3 class="text-2xl font-['Playfair_Display'] font-bold text-[var(--primary)]">2012</h3>
            <p class="text-gray-600 mt-2">Founded by a group of passionate local historians.</p>
          </div>
          <div class="relative">
            <div class="absolute -left-[41px] top-1 w-5 h-5 rounded-full bg-[var(--gold)] border-4 border-white shadow-md"></div>
            <h3 class="text-2xl font-['Playfair_Display'] font-bold text-[var(--primary)]">2016</h3>
            <p class="text-gray-600 mt-2">Expanded to include exclusive private tours and Skip the Line access.</p>
          </div>
          <div class="relative">
            <div class="absolute -left-[41px] top-1 w-5 h-5 rounded-full bg-[var(--accent)] border-4 border-white shadow-md shadow-[var(--accent-glow)]"></div>
            <h3 class="text-2xl font-['Playfair_Display'] font-bold text-[var(--primary)]">Present</h3>
            <p class="text-gray-600 mt-2">Award-winning experiences maintaining our "Quality over Quantity" promise.</p>
          </div>
        </div>

        <!-- Editorial -->
        <div class="space-y-6 text-lg text-gray-700 leading-relaxed font-light">
          <p>
            Born out of a deep love for our beautiful home city, we've spent over two decades crafting unforgettable experiences that immerse you in the rich history and culture of Barcelona.
          </p>
          <blockquote class="border-l-4 border-[var(--accent)] pl-6 italic font-['Playfair_Display'] text-2xl text-[var(--primary)] my-8">
            "For us, you're more than just a guest; you're part of our story."
          </blockquote>
          <p>
            Our mission has always been clear: to offer tours that go beyond the ordinary. With expert guides who live and breathe the essence of Barcelona, we're dedicated to bringing you closer to the stories, sights, and spirit of the city.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Stats Section (Animated Counters) -->
  <section class="py-20 bg-[var(--primary)] text-white relative overflow-hidden">
    <div class="absolute inset-0 opacity-5" style="background-image: radial-gradient(circle at 2px 2px, white 1px, transparent 0); background-size: 32px 32px;"></div>
    <div class="container relative z-10">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 text-center" id="stats-container">
        <div class="p-6">
          <div class="text-5xl md:text-6xl font-bold font-['Playfair_Display'] text-[var(--gold)] mb-2"><span class="counter" data-target="12">0</span>+</div>
          <p class="uppercase tracking-widest text-sm font-semibold opacity-80">Years Experience</p>
        </div>
        <div class="p-6">
          <div class="text-5xl md:text-6xl font-bold font-['Playfair_Display'] text-[var(--accent)] mb-2"><span class="counter" data-target="50">0</span>k+</div>
          <p class="uppercase tracking-widest text-sm font-semibold opacity-80">Happy Guests</p>
        </div>
        <div class="p-6">
          <div class="text-5xl md:text-6xl font-bold font-['Playfair_Display'] text-[var(--gold)] mb-2"><span class="counter-decimal" data-target="4.9">0.0</span></div>
          <p class="uppercase tracking-widest text-sm font-semibold opacity-80">Average Rating</p>
        </div>
        <div class="p-6">
          <div class="text-5xl md:text-6xl font-bold font-['Playfair_Display'] text-[var(--accent)] mb-2"><span class="counter" data-target="4">0</span></div>
          <p class="uppercase tracking-widest text-sm font-semibold opacity-80">Premium Tours</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Values/Team Cards -->
  <section class="py-24 bg-gray-50">
    <div class="container">
      <div class="text-center mb-16">
        <h2 class="text-4xl font-['Playfair_Display'] font-bold text-[var(--primary)]">The 4U Difference</h2>
        <div class="w-24 h-1 bg-[var(--accent)] mx-auto mt-6"></div>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <!-- Card 1 -->
        <div class="bg-white p-10 rounded-2xl shadow-lg hover:-translate-y-2 transition-all duration-300 group border border-gray-100">
          <div class="w-16 h-16 rounded-full bg-[var(--primary)] text-white flex items-center justify-center text-2xl mb-6 group-hover:scale-110 group-hover:bg-[var(--accent)] transition-all">🗺️</div>
          <h3 class="text-xl font-bold font-['Playfair_Display'] mb-4 text-[var(--primary)]">Local Expertise</h3>
          <p class="text-gray-600 leading-relaxed">Our guides aren't just reciting scripts. They are deeply rooted locals and trained historians bringing the city's hidden narratives to life.</p>
        </div>
        <!-- Card 2 -->
        <div class="bg-white p-10 rounded-2xl shadow-lg hover:-translate-y-2 transition-all duration-300 group border border-gray-100">
          <div class="w-16 h-16 rounded-full bg-[var(--primary)] text-white flex items-center justify-center text-2xl mb-6 group-hover:scale-110 group-hover:bg-[var(--gold)] transition-all">👥</div>
          <h3 class="text-xl font-bold font-['Playfair_Display'] mb-4 text-[var(--primary)]">Intimate Groups</h3>
          <p class="text-gray-600 leading-relaxed">We strictly cap our semi-private tours at 9 guests to ensure a conversational, personalized pace rather than a crowded march.</p>
        </div>
        <!-- Card 3 -->
        <div class="bg-white p-10 rounded-2xl shadow-lg hover:-translate-y-2 transition-all duration-300 group border border-gray-100">
          <div class="w-16 h-16 rounded-full bg-[var(--primary)] text-white flex items-center justify-center text-2xl mb-6 group-hover:scale-110 group-hover:bg-[var(--accent)] transition-all">✨</div>
          <h3 class="text-xl font-bold font-['Playfair_Display'] mb-4 text-[var(--primary)]">Authentic Magic</h3>
          <p class="text-gray-600 leading-relaxed">We skip the tourist traps to deliver genuine connections, seamless logistics, and Priority Access at all major monuments.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Photo Mosaic -->
  <section class="py-20 bg-white">
    <div class="container">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 h-[600px]">
        <div class="col-span-2 row-span-2 rounded-2xl overflow-hidden shadow-md group">
          <img src="https://images.unsplash.com/photo-1511527661048-7fe73d85e9a4?w=800&q=80" alt="Barcelona street" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700">
        </div>
        <div class="rounded-2xl overflow-hidden shadow-md group">
          <img src="https://images.unsplash.com/photo-1539037116277-4db20889f2d4?w=500&q=80" alt="Gothic detail" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700">
        </div>
        <div class="row-span-2 rounded-2xl overflow-hidden shadow-md group">
          <img src="https://images.unsplash.com/photo-1579282240050-352db0a14c21?w=500&q=80" alt="Park Guell" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700">
        </div>
        <div class="rounded-2xl overflow-hidden shadow-md group">
          <img src="https://images.unsplash.com/photo-1564760055775-d63b17a55c44?w=500&q=80" alt="Sagrada" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700">
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-24 bg-[var(--primary)] text-center text-white">
    <div class="container">
      <h2 class="text-4xl font-['Playfair_Display'] font-bold mb-6">Ready to explore Barcelona?</h2>
      <p class="text-xl font-light mb-10 max-w-2xl mx-auto opacity-90">Join us for a journey through history, art, and the vibrant life of Catalonia's capital.</p>
      <a href="/" class="inline-block bg-[var(--gold)] text-[var(--primary)] px-10 py-4 rounded-full font-bold text-lg hover:bg-white transition-colors shadow-lg hover:shadow-xl transform hover:-translate-y-1">Book Your Tour</a>
    </div>
  </section>

  <Footer slot="footer" />

  <style>
    @keyframes pan {
      0% { transform: scale(1.05) translate(0, 0); }
      50% { transform: scale(1.1) translate(-2%, 2%); }
      100% { transform: scale(1.05) translate(0, 0); }
    }
    .animate-pan {
      animation: pan 30s ease-in-out infinite;
    }
    
    @keyframes fade-up {
      0% { opacity: 0; transform: translateY(30px); }
      100% { opacity: 1; transform: translateY(0); }
    }
    .animate-fade-up {
      animation: fade-up 1s cubic-bezier(0.16, 1, 0.3, 1);
    }
  </style>

  <script>
    // Counter Animation Logic
    document.addEventListener('DOMContentLoaded', () => {
      const counters = document.querySelectorAll('.counter');
      const decimalCounters = document.querySelectorAll('.counter-decimal');
      
      const runCounter = (el, isDecimal = false) => {
        const target = parseFloat(el.getAttribute('data-target'));
        const duration = 2000; // ms
        const steps = 60;
        const stepTime = Math.abs(Math.floor(duration / steps));
        const increment = target / steps;
        let current = 0;
        
        const timer = setInterval(() => {
          current += increment;
          if (current >= target) {
            el.innerText = isDecimal ? target.toFixed(1) : Math.floor(target);
            clearInterval(timer);
          } else {
            el.innerText = isDecimal ? current.toFixed(1) : Math.floor(current);
          }
        }, stepTime);
      };

      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            counters.forEach(c => runCounter(c, false));
            decimalCounters.forEach(c => runCounter(c, true));
            observer.disconnect(); // Run once
          }
        });
      }, { threshold: 0.5 });

      const container = document.getElementById('stats-container');
      if(container) observer.observe(container);
    });
  </script>
</Layout>
