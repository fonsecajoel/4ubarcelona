---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Bike Tour">
  <Navbar slot="navbar" scrolled={true} />
  
  

  <section class="tour-hero">
    <div class="tour-hero-bg" style="background-image: url('https://images.unsplash.com/photo-1558618666-fcd25c85f82e?w=1920&q=80')"></div>
    <div class="tour-hero-content">
      <div class="container">
        <span class="tour-card-tag">Private Tour</span>
        <h1>Bike Tour Barcelona</h1>
        <p style="font-size: 1.2rem; opacity: 0.9; max-width: 600px;">Enjoy Barcelona in style with this exclusive 2-hour private bike experience.</p>
      </div>
    </div>
  </section>

  <section>
    <div class="container">
      <div class="tour-details">
        <div class="tour-info">
          <h2>Private Bike Tour of Barcelona</h2>
          <p>Discover Barcelona on two wheels with a private guided experience tailored to your pace. This relaxed tour combines coastal views, historic neighborhoods, and iconic landmarks for a safe and memorable ride.</p>

          <div class="info-grid">
            <div class="info-item">
              <div class="icon">⏱</div>
              <div><div class="label">Duration</div><div class="value">2 hours</div></div>
            </div>
            <div class="info-item">
              <div class="icon">👥</div>
              <div><div class="label">Tour Type</div><div class="value">Private guided bike tour</div></div>
            </div>
            <div class="info-item">
              <div class="icon">🌐</div>
              <div><div class="label">Languages</div><div class="value">EN/FR/PT/RU</div></div>
            </div>
            <div class="info-item">
              <div class="icon">🎟</div>
              <div><div class="label">Included</div><div class="value">Helmet included</div></div>
            </div>
          </div>

          <h3 style="margin-top: 40px;">Tour Highlights</h3>
          <ul class="tour-highlights">
            <li>Dedicated cycling paths throughout</li>
            <li>Private guide adapts pace to you</li>
            <li>Coastal ride along Mediterranean</li>
            <li>Parc de la Ciutadella green oasis</li>
            <li>Historic districts El Born & Barceloneta</li>
            <li>Safe and relaxed experience</li>
          </ul>

          <h3 style="margin-top: 40px;">Itinerary</h3>
          <div class="itinerary">
            <div class="itinerary-step">
              <div class="itinerary-number">1</div>
              <div>
                <h4>Port Vell</h4>
                <p>Picturesque waterfront where the old harbor meets modern Barcelona.</p>
              </div>
            </div>
            <div class="itinerary-step">
              <div class="itinerary-number">2</div>
              <div>
                <h4>Columbus Monument</h4>
                <p>Gateway to the historic center.</p>
              </div>
            </div>
            <div class="itinerary-step">
              <div class="itinerary-number">3</div>
              <div>
                <h4>Barceloneta</h4>
                <p>Seaside district with beaches and an authentic atmosphere.</p>
              </div>
            </div>
            <div class="itinerary-step">
              <div class="itinerary-number">4</div>
              <div>
                <h4>Parc de la Ciutadella</h4>
                <p>Lush green paths and a peaceful oasis in the city.</p>
              </div>
            </div>
            <div class="itinerary-step">
              <div class="itinerary-number">5</div>
              <div>
                <h4>Arc de Triomf</h4>
                <p>Elegant landmark with a striking presence.</p>
              </div>
            </div>
            <div class="itinerary-step">
              <div class="itinerary-number">6</div>
              <div>
                <h4>El Born</h4>
                <p>Charming streets where history meets contemporary life.</p>
              </div>
            </div>
          </div>
        </div>

        <div class="tour-booking">
          <h3>Book Your Experience</h3>
          <p style="text-align:center; color: var(--gray-600); margin-bottom: 24px;">Limited availability – advance booking recommended</p>
          <form>
            <div class="form-group">
              <label>Date</label>
              <input type="date" required>
            </div>
            <div class="form-group">
              <label>Number of Guests (Max 9)</label>
              <select required>
                <option value="">Select</option>
                <option>1</option>
                <option>2</option>
                <option>3</option>
                <option>4</option>
                <option>5</option>
                <option>6</option>
                <option>7</option>
                <option>8</option>
                <option>9</option>
              </select>
            </div>
            <div class="form-group">
              <label>Tour Type</label>
              <select required>
                <option value="private">Private Tour</option>
              </select>
            </div>
            <div class="form-group">
              <label>Language</label>
              <select required>
                <option value="en">English</option>
                <option value="fr">Français</option>
                <option value="pt">Português</option>
                <option value="ru">Русский</option>
              </select>
            </div>
            <div class="form-group">
              <label>Full Name</label>
              <input type="text" placeholder="Your name" required>
            </div>
            <div class="form-group">
              <label>Email</label>
              <input type="email" placeholder="your@email.com" required>
            </div>
            <button type="submit" class="btn btn-gold" style="width: 100%; justify-content: center;" data-i18n="book_now">Book Now</button>
          </form>
        </div>
      </div>
    </div>
  </section>

  
  <script src="/scripts/booking.js" type="module"></script>
  <Footer slot="footer" />
</Layout>
