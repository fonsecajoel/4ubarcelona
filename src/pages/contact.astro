---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Contact Us">
  <Navbar slot="navbar" scrolled={true} />

  <section style="background:var(--primary);padding-top:6rem;padding-bottom:4rem;text-align:center;color:white;position:relative;overflow:hidden;">
    <div style="position:absolute;inset:0;opacity:0.06;background-image:radial-gradient(circle at 2px 2px, white 1px, transparent 0);background-size:32px 32px;"></div>
    <div class="container" style="position:relative;z-index:1;">
      <h1 style="font-family:'Playfair Display',serif;font-size:clamp(2.5rem,7vw,5rem);font-weight:700;margin-bottom:1rem;" data-i18n="contact_title">Get In Touch</h1>
      <p style="font-size:1.2rem;font-weight:300;opacity:0.85;max-width:600px;margin:0 auto;" data-i18n="contact_sub">We'd love to hear from you. Our team responds within 24 hours.</p>
    </div>
  </section>

  <section style="padding:4rem 0 5rem;background:#f8f9fa;">
    <div class="container">

      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:1.5rem;margin-bottom:3rem;">
        <div style="background:white;border-radius:1rem;padding:2rem;text-align:center;box-shadow:0 4px 20px rgba(0,0,0,0.07);border:1px solid #f0f0f0;">
          <div style="font-size:2.5rem;margin-bottom:1rem;">✉️</div>
          <h3 style="font-family:'Playfair Display',serif;font-weight:700;color:var(--primary);margin-bottom:0.5rem;" data-i18n="contact_email_label">Email Us</h3>
          <a href="mailto:info@4ubarcelona.com" style="color:var(--accent);text-decoration:none;font-weight:500;">info@4ubarcelona.com</a>
        </div>
        <div style="background:white;border-radius:1rem;padding:2rem;text-align:center;box-shadow:0 4px 20px rgba(0,0,0,0.07);border:1px solid #f0f0f0;">
          <div style="font-size:2.5rem;margin-bottom:1rem;">📞</div>
          <h3 style="font-family:'Playfair Display',serif;font-weight:700;color:var(--primary);margin-bottom:0.5rem;" data-i18n="contact_phone_label">Call Us</h3>
          <a href="tel:+34663331088" style="color:var(--accent);text-decoration:none;font-weight:500;">+34 663 331 088</a>
        </div>
        <div style="background:white;border-radius:1rem;padding:2rem;text-align:center;box-shadow:0 4px 20px rgba(0,0,0,0.07);border:1px solid #f0f0f0;">
          <div style="font-size:2.5rem;margin-bottom:1rem;">📍</div>
          <h3 style="font-family:'Playfair Display',serif;font-weight:700;color:var(--primary);margin-bottom:0.5rem;" data-i18n="contact_location_label">Based In</h3>
          <p style="color:#6c757d;margin:0;">Barcelona, Spain</p>
        </div>
      </div>

      <div style="display:grid;grid-template-columns:1fr 1fr;gap:3rem;" class="contact-main-grid">

        <div style="display:flex;flex-direction:column;gap:2rem;">
          <div>
            <h2 style="font-family:'Playfair Display',serif;font-size:clamp(1.8rem,3vw,2.5rem);font-weight:700;color:var(--primary);margin-bottom:1rem;">
              <span data-i18n="contact_plan_title">Let's Plan Your </span><span style="color:var(--accent);" data-i18n="contact_plan_highlight">Barcelona Experience</span>
            </h2>
            <p style="color:#6c757d;font-size:1.05rem;line-height:1.7;" data-i18n="contact_plan_desc">Whether you have a question about one of our tours, need a custom group experience, or simply want to know more about Barcelona — we're here for you.</p>
          </div>
          <div style="display:flex;flex-wrap:wrap;gap:0.75rem;">
            <a href="https://www.instagram.com/4ubarcelona/" target="_blank" style="display:inline-flex;align-items:center;gap:0.4rem;padding:0.6rem 1.25rem;border-radius:9999px;background:var(--primary);color:white;text-decoration:none;font-weight:600;font-size:0.9rem;">📷 Instagram</a>
            <a href="https://www.facebook.com/profile.php?id=61564466648421" target="_blank" style="display:inline-flex;align-items:center;gap:0.4rem;padding:0.6rem 1.25rem;border-radius:9999px;background:var(--primary);color:white;text-decoration:none;font-weight:600;font-size:0.9rem;">📘 Facebook</a>
            <a href="https://www.tiktok.com/@4ubarcelona" target="_blank" style="display:inline-flex;align-items:center;gap:0.4rem;padding:0.6rem 1.25rem;border-radius:9999px;background:var(--primary);color:white;text-decoration:none;font-weight:600;font-size:0.9rem;">🎵 TikTok</a>
          </div>
          <div style="background:white;border-radius:1rem;padding:2rem;box-shadow:0 4px 20px rgba(0,0,0,0.07);border:1px solid #f0f0f0;">
            <h4 style="font-family:'Playfair Display',serif;font-weight:700;color:var(--primary);margin-bottom:1.25rem;" data-i18n="contact_hours_title">Response Hours</h4>
            <div style="display:flex;justify-content:space-between;padding:0.6rem 0;border-bottom:1px solid #f0f0f0;">
              <span style="color:#6c757d;" data-i18n="contact_hours_weekday">Monday – Friday</span>
              <span style="font-weight:600;color:var(--primary);">9:00 – 20:00</span>
            </div>
            <div style="display:flex;justify-content:space-between;padding:0.6rem 0;border-bottom:1px solid #f0f0f0;">
              <span style="color:#6c757d;" data-i18n="contact_hours_sat">Saturday</span>
              <span style="font-weight:600;color:var(--primary);">10:00 – 18:00</span>
            </div>
            <div style="display:flex;justify-content:space-between;padding:0.6rem 0;">
              <span style="color:#6c757d;" data-i18n="contact_hours_sun">Sunday</span>
              <span style="font-weight:600;color:var(--primary);">10:00 – 15:00</span>
            </div>
          </div>
        </div>

        <div style="background:white;border-radius:1.25rem;padding:2.5rem;box-shadow:0 8px 40px rgba(0,0,0,0.1);border:1px solid #f0f0f0;">
          <h2 style="font-family:'Playfair Display',serif;font-size:1.75rem;font-weight:700;color:var(--primary);margin-bottom:0.5rem;" data-i18n="contact_form_title">Send Us a Message</h2>
          <p style="color:#9ca3af;margin-bottom:2rem;" data-i18n="contact_form_sub">Fill in the form below and we'll get back to you as soon as possible.</p>
          <form id="contact-form" style="display:flex;flex-direction:column;gap:1.25rem;">
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;">
              <div>
                <label style="display:block;font-size:0.85rem;font-weight:600;color:#374151;margin-bottom:0.35rem;" data-i18n="contact_firstname">First Name</label>
                <input type="text" placeholder="John" required class="contact-input" />
              </div>
              <div>
                <label style="display:block;font-size:0.85rem;font-weight:600;color:#374151;margin-bottom:0.35rem;" data-i18n="contact_lastname">Last Name</label>
                <input type="text" placeholder="Doe" required class="contact-input" />
              </div>
            </div>
            <div>
              <label style="display:block;font-size:0.85rem;font-weight:600;color:#374151;margin-bottom:0.35rem;" data-i18n="contact_email">Email Address</label>
              <input type="email" placeholder="john@example.com" required class="contact-input" />
            </div>
            <div>
              <label style="display:block;font-size:0.85rem;font-weight:600;color:#374151;margin-bottom:0.35rem;" data-i18n="contact_subject">Subject</label>
              <select class="contact-input">
                <option value="" data-i18n="contact_subject_placeholder">Select a topic...</option>
                <option>Sagrada Familia Tour</option>
                <option>Park Guell Tour</option>
                <option>Gothic Quarter Tour</option>
                <option>Bike Tour</option>
                <option data-i18n="contact_subject_private">Private Group Booking</option>
                <option data-i18n="contact_subject_general">General Question</option>
              </select>
            </div>
            <div>
              <label style="display:block;font-size:0.85rem;font-weight:600;color:#374151;margin-bottom:0.35rem;" data-i18n="contact_message">Message</label>
              <textarea rows="5" required class="contact-input" style="resize:none;" placeholder="Tell us about your trip, group size, preferred dates..."></textarea>
            </div>
            <button type="submit" style="width:100%;padding:1rem;border-radius:0.75rem;background:var(--primary);color:white;font-weight:700;font-size:1rem;border:none;cursor:pointer;" data-i18n="contact_send">Send Message</button>
          </form>
          <div id="form-success" style="display:none;text-align:center;padding:3rem 1rem;">
            <div style="font-size:3.5rem;margin-bottom:1rem;">✅</div>
            <h3 style="font-family:'Playfair Display',serif;font-size:1.5rem;font-weight:700;color:var(--primary);margin-bottom:0.5rem;" data-i18n="contact_success_title">Message Sent!</h3>
            <p style="color:#9ca3af;" data-i18n="contact_success_sub">Thank you for reaching out. We'll reply within 24 hours.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</Layout>

<style is:global>
  .contact-input {
    width: 100%;
    padding: 0.75rem 1rem;
    border-radius: 0.625rem;
    border: 1.5px solid #e5e7eb;
    outline: none;
    font-size: 1rem;
    color: #1f2937;
    background: white;
    transition: border-color 0.2s;
    font-family: inherit;
  }
  .contact-input:focus { border-color: var(--accent); }
  @media (max-width: 768px) {
    .contact-main-grid { grid-template-columns: 1fr !important; }
  }
</style>

<script>
  const form = document.getElementById('contact-form');
  const success = document.getElementById('form-success');
  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    if (form) form.style.display = 'none';
    if (success) success.style.display = 'block';
  });
</script>