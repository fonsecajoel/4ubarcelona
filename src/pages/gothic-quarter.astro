---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Gothic Quarter Tour">
  <Navbar slot="navbar" scrolled={true} />
  
  

  <section class="tour-hero">
    <div class="tour-hero-bg" style="background-image: url('https://images.unsplash.com/photo-1539037116277-4db20889f2d4?w=1920&q=80')"></div>
    <div class="tour-hero-content">
      <div class="container">
        <span class="tour-card-tag">Private Tour</span>
        <h1>Gothic Quarter</h1>
        <p style="font-size: 1.2rem; opacity: 0.9; max-width: 600px;">Step into the timeless elegance of Barcelona's historic heart.</p>
      </div>
    </div>
  </section>

  <section>
    <div class="container">
      <div class="tour-details">
        <div class="tour-info">
          <h2>Private Tour of the Gothic Quarter</h2>
          <p>Walk through centuries of Barcelona history in the city's most atmospheric neighborhood. This private experience reveals Roman origins, medieval squares, and iconic corners that define the Gothic Quarter's enduring charm.</p>

          <div class="info-grid">
            <div class="info-item">
              <div class="icon">⏱</div>
              <div><div class="label">Duration</div><div class="value">2 hours</div></div>
            </div>
            <div class="info-item">
              <div class="icon">👥</div>
              <div><div class="label">Group Size</div><div class="value">Private walking tour</div></div>
            </div>
            <div class="info-item">
              <div class="icon">🌐</div>
              <div><div class="label">Languages</div><div class="value">EN, FR, PT, RU</div></div>
            </div>
            <div class="info-item">
              <div class="icon">🎟</div>
              <div><div class="label">Tickets</div><div class="value">No tickets needed</div></div>
            </div>
          </div>

          <h3 style="margin-top: 40px;">Tour Highlights</h3>
          <ul class="tour-highlights">
            <li>Barcelona Cathedral with rich Gothic details</li>
            <li>Plaça del Rei medieval square</li>
            <li>Ancient Roman walls and columns</li>
            <li>Plaça Sant Jaume, the political heart of the city</li>
            <li>Plaça Sant Felip Neri, where history meets emotion</li>
            <li>Carrer del Bisbe iconic corner</li>
            <li>Plaça Reial with palm-lined arcades</li>
          </ul>

          <h3 style="margin-top: 40px;">Itinerary</h3>
          <div class="itinerary">
            <div class="itinerary-step">
              <div class="itinerary-number">1</div>
              <div>
                <h4>Barcelona Cathedral</h4>
                <p>Admire Gothic architecture and uncover centuries of history at the heart of the old city.</p>
              </div>
            </div>
            <div class="itinerary-step">
              <div class="itinerary-number">2</div>
              <div>
                <h4>Plaça del Rei</h4>
                <p>Explore the square of royal ceremonies and stories tied to Columbus' return.</p>
              </div>
            </div>
            <div class="itinerary-step">
              <div class="itinerary-number">3</div>
              <div>
                <h4>Roman Foundations</h4>
                <p>See preserved walls and columns that reveal the origins of the city.</p>
              </div>
            </div>
            <div class="itinerary-step">
              <div class="itinerary-number">4</div>
              <div>
                <h4>Plaça Sant Jaume</h4>
                <p>Discover Catalonia's identity through its key political institutions and public square.</p>
              </div>
            </div>
            <div class="itinerary-step">
              <div class="itinerary-number">5</div>
              <div>
                <h4>Sant Felip Neri & Carrer del Bisbe</h4>
                <p>Visit hidden gems and iconic photo spots with deep historical resonance.</p>
              </div>
            </div>
            <div class="itinerary-step">
              <div class="itinerary-number">6</div>
              <div>
                <h4>Plaça Reial</h4>
                <p>End among elegant arcades where La Rambla's energy meets classic Barcelona style.</p>
              </div>
            </div>
          </div>
        </div>

        <div class="tour-booking">
          <h3>Book Your Experience</h3>
          <p style="text-align:center; color: var(--gray-600); margin-bottom: 24px;">Limited availability – advance booking recommended</p>
          <form>
            <div class="form-group">
              <label>Date</label>
              <input type="date" required>
            </div>
            <div class="form-group">
              <label>Number of Guests (Max 9)</label>
              <select required>
                <option value="">Select</option>
                <option>1</option>
                <option>2</option>
                <option>3</option>
                <option>4</option>
                <option>5</option>
                <option>6</option>
                <option>7</option>
                <option>8</option>
                <option>9</option>
              </select>
            </div>
            <div class="form-group">
              <label>Tour Type</label>
              <select required>
                <option value="private">Private Tour</option>
              </select>
            </div>
            <div class="form-group">
              <label>Language</label>
              <select required>
                <option value="en">English</option>
                <option value="fr">Français</option>
                <option value="pt">Português</option>
                <option value="ru">Русский</option>
              </select>
            </div>
            <div class="form-group">
              <label>Full Name</label>
              <input type="text" placeholder="Your name" required>
            </div>
            <div class="form-group">
              <label>Email</label>
              <input type="email" placeholder="your@email.com" required>
            </div>
            <button type="submit" class="btn btn-gold" style="width: 100%; justify-content: center;" data-i18n="book_now">Book Now</button>
          </form>
        </div>
      </div>
    </div>
  </section>

  
  <script src="/scripts/booking.js" type="module"></script>
  <Footer slot="footer" />
</Layout>
