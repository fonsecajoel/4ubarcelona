---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Park Güell Tour">
  <Navbar slot="navbar" scrolled={true} />
  
  

  <section class="tour-hero">
    <div class="tour-hero-bg" style="background-image: url('https://images.unsplash.com/photo-1579282240050-352db0a14c21?w=1920&q=80')"></div>
    <div class="tour-hero-content">
      <div class="container">
        <span class="tour-card-tag">Private Tour</span>
        <h1>Park Güell</h1>
        <p style="font-size: 1.2rem; opacity: 0.9; max-width: 600px;">Discover Gaudí's colorful mosaic wonderland. Exclusive private experience.</p>
      </div>
    </div>
  </section>

  <section>
    <div class="container">
      <div class="tour-details">
        <div class="tour-info">
          <h2>Private Tour of Park Güell</h2>
          <p>Explore one of Barcelona's most iconic landmarks with a private guide. This exclusive Park Güell experience brings Gaudí's imaginative world to life through vibrant mosaics, flowing forms, and panoramic city views.</p>

          <div class="info-grid">
            <div class="info-item">
              <div class="icon">⏱</div>
              <div><div class="label">Duration</div><div class="value">1.5 hours</div></div>
            </div>
            <div class="info-item">
              <div class="icon">👥</div>
              <div><div class="label">Group Size</div><div class="value">Private tour</div></div>
            </div>
            <div class="info-item">
              <div class="icon">🌐</div>
              <div><div class="label">Languages</div><div class="value">EN/FR/PT/RU</div></div>
            </div>
            <div class="info-item">
              <div class="icon">🎟</div>
              <div><div class="label">Tickets</div><div class="value">Included</div></div>
            </div>
          </div>

          <h3 style="margin-top: 40px;">Tour Highlights</h3>
          <ul class="tour-highlights">
            <li>Dragon staircase & mosaic salamander</li>
            <li>Hypostyle Room with Doric columns</li>
            <li>Panoramic terrace with serpentine bench</li>
            <li>Breathtaking views over Barcelona</li>
            <li>Landscaped pathways and viaducts</li>
            <li>Gaudí House Museum exterior</li>
          </ul>

          <h3 style="margin-top: 40px;">Itinerary</h3>
          <div class="itinerary">
            <div class="itinerary-step">
              <div class="itinerary-number">1</div>
              <div>
                <h4>Monumental Entrance</h4>
                <p>Admire the dragon staircase and the iconic mosaic salamander that greet visitors with Gaudí's signature color and symbolism.</p>
              </div>
            </div>
            <div class="itinerary-step">
              <div class="itinerary-number">2</div>
              <div>
                <h4>Hypostyle Room</h4>
                <p>Walk through the forest of Doric columns and learn how this space was originally designed as a marketplace.</p>
              </div>
            </div>
            <div class="itinerary-step">
              <div class="itinerary-number">3</div>
              <div>
                <h4>Panoramic Terrace</h4>
                <p>Enjoy the serpentine bench and take in sweeping city views from one of Barcelona's most recognizable viewpoints.</p>
              </div>
            </div>
            <div class="itinerary-step">
              <div class="itinerary-number">4</div>
              <div>
                <h4>Landscaped Pathways</h4>
                <p>Stroll the viaducts and winding paths integrated into nature, showcasing Gaudí's harmony between architecture and landscape.</p>
              </div>
            </div>
          </div>

          <h3 style="margin-top: 40px;">Optional Enhancements</h3>
          <ul class="tour-highlights">
            <li>Extended Gaudí-focused tour</li>
            <li>Sunset photography stop</li>
          </ul>

          <div style="margin-top: 40px; padding: 24px; background: var(--gray-100); border-radius: var(--radius-sm);">
            <p><strong>Dress Code:</strong> Comfortable walking shoes recommended</p>
            <p style="margin-top: 8px;"><strong>Accessibility:</strong> Please inquire for specific needs</p>
          </div>
        </div>

        <div class="tour-booking">
          <h3>Book Your Experience</h3>
          <p style="text-align:center; color: var(--gray-600); margin-bottom: 24px;">Limited availability – advance booking recommended</p>
          <form>
            <div class="form-group">
              <label>Date</label>
              <input type="date" required>
            </div>
            <div class="form-group">
              <label>Number of Guests (Max 9)</label>
              <select required>
                <option value="">Select</option>
                <option>1</option>
                <option>2</option>
                <option>3</option>
                <option>4</option>
                <option>5</option>
                <option>6</option>
                <option>7</option>
                <option>8</option>
                <option>9</option>
              </select>
            </div>
            <div class="form-group">
              <label>Tour Type</label>
              <select required>
                <option value="semi-private">Semi-Private (Max 9)</option>
                <option value="private" selected>Private Tour</option>
              </select>
            </div>
            <div class="form-group">
              <label>Language</label>
              <select required>
                <option value="en">English</option>
                <option value="fr">Français</option>
                <option value="pt">Português</option>
                <option value="ru">Русский</option>
              </select>
            </div>
            <div class="form-group">
              <label>Full Name</label>
              <input type="text" placeholder="Your name" required>
            </div>
            <div class="form-group">
              <label>Email</label>
              <input type="email" placeholder="your@email.com" required>
            </div>
            <button type="submit" class="btn btn-gold" style="width: 100%; justify-content: center;" data-i18n="book_now">Book Now</button>
          </form>
        </div>
      </div>
    </div>
  </section>

  
  <script src="/scripts/booking.js" type="module"></script>
  <Footer slot="footer" />
</Layout>
